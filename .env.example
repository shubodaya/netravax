# Optional Cloudflare Pages Function settings for /api/contact.
# Do not expose these values to client-side code.
NETRAVAX_CONTACT_WEBHOOK_URL=
TURNSTILE_SECRET_KEY=

# Public Cloudflare Turnstile site key, injected into the client at build time.
# This value is PUBLIC (safe to expose in the browser). Leave empty to keep the
# widget disabled; the contact form then relies on the honeypot + timing checks.
# Pair this with TURNSTILE_SECRET_KEY above to enable full verification.
VITE_TURNSTILE_SITE_KEY=
